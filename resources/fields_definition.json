{
  "version": "1.0",
  "last_updated": "2024-01-01",
  "basic_info_fields": [
    {
      "key": "姓名",
      "type": "text",
      "required": true,
      "validation": {
        "min_length": 2,
        "max_length": 20,
        "pattern": "^[\\u4e00-\\u9fa5a-zA-Z\\s]+$"
      },
      "display": {
        "label": "姓名",
        "placeholder": "请输入真实姓名",
        "order": 1
      }
    },
    {
      "key": "性别",
      "type": "select",
      "required": true,
      "options": ["男", "女"],
      "display": {
        "label": "性别",
        "order": 2
      }
    },
    {
      "key": "出生年月",
      "type": "date",
      "required": true,
      "format": "YYYY年MM月",
      "display": {
        "label": "出生年月",
        "order": 3
      }
    },
    {
      "key": "民族",
      "type": "text",
      "required": true,
      "display": {
        "label": "民族",
        "order": 4
      }
    },
    {
      "key": "籍贯",
      "type": "text",
      "required": true,
      "display": {
        "label": "籍贯",
        "order": 5
      }
    },
    {
      "key": "身份证号",
      "type": "text",
      "required": true,
      "validation": {
        "pattern": "^[1-9]\\d{5}(18|19|20)\\d{2}(0[1-9]|1[0-2])(0[1-9]|[12]\\d|3[01])\\d{3}[0-9Xx]$"
      },
      "display": {
        "label": "身份证号",
        "order": 6
      }
    },
    {
      "key": "申请时间",
      "type": "date",
      "required": true,
      "format": "YYYY年MM月DD日",
      "display": {
        "label": "申请时间",
        "order": 7
      }
    },
    {
      "key": "联系电话",
      "type": "text",
      "required": true,
      "validation": {
        "pattern": "^1[3-9]\\d{9}$"
      },
      "display": {
        "label": "联系电话",
        "order": 8
      }
    },
    {
      "key": "家庭住址",
      "type": "text",
      "required": false,
      "display": {
        "label": "家庭住址",
        "order": 9
      }
    }
  ],
  "admin_fields": [
    {
      "group": "支部信息",
      "group_order": 1,
      "fields": [
        {
          "key": "branch_name",
          "path": "branch_info.branch_name",
          "type": "text",
          "required": true,
          "display": {
            "label": "支部名称",
            "order": 1
          }
        },
        {
          "key": "branch_code",
          "path": "branch_info.branch_code",
          "type": "text",
          "required": false,
          "display": {
            "label": "支部代码",
            "order": 2
          }
        },
        {
          "key": "branch_secretary",
          "path": "branch_info.secretary.name",
          "type": "text",
          "required": true,
          "display": {
            "label": "支部书记",
            "order": 3
          }
        }
      ]
    },
    {
      "group": "上级党委信息",
      "group_order": 2,
      "fields": [
        {
          "key": "committee_name",
          "path": "party_committee.name",
          "type": "text",
          "required": true,
          "display": {
            "label": "党委名称",
            "order": 1
          }
        },
        {
          "key": "committee_secretary",
          "path": "party_committee.secretary.name",
          "type": "text",
          "required": true,
          "display": {
            "label": "党委书记",
            "order": 2
          }
        },
        {
          "key": "mynew",
          "path": "party_committee.mynew.name",
          "type": "text",
          "required": true,
          "display": {
            "label": "我新的",
            "order": 3
          }
        }
      ]
    },
    {
      "group": "公共字段",
      "group_order": 3,
      "fields": [
        {
          "key": "school_name",
          "path": "common_fields.school_name",
          "type": "text",
          "required": true,
          "display": {
            "label": "学校名称",
            "order": 1
          }
        },
        {
          "key": "college_name",
          "path": "common_fields.college_name",
          "type": "text",
          "required": true,
          "display": {
            "label": "学院名称",
            "order": 2
          }
        }
      ]
    },
    {
      "group": "系统设置",
      "group_order": 4,
      "fields": [
        {
          "key": "export_path",
          "path": "system_settings.export_path",
          "type": "text",
          "required": false,
          "display": {
            "label": "默认导出路径",
            "placeholder": "./exports",
            "order": 1
          }
        },
        {
          "key": "date_format",
          "path": "date_format.format",
          "type": "text",
          "required": false,
          "display": {
            "label": "日期显示格式",
            "placeholder": "例如：YYYY年MM月DD日 或 YYYY年MM月",
            "order": 2
          }
        },
        {
          "key": "config_sync_url",
          "path": "system_settings.config_sync_url",
          "type": "text",
          "required": false,
          "display": {
            "label": "配置同步 URL（可选）",
            "placeholder": "例如：https://example.com/config.json 或 https://raw.githubusercontent.com/user/repo/branch/config.json",
            "order": 3
          }
        }
      ]
    }
  ],
  "common_template_fields": [
    {
      "key": "入党时间",
